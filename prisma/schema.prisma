// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model KGNode {
  id          String   @id
  label       String
  type        String   // concept, theorem, method, application
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourceEdges KGEdge[] @relation("SourceNode")
  targetEdges KGEdge[] @relation("TargetNode")
}

model KGEdge {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  relation  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source KGNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target KGNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relation])
}
